{
  "title": "AC Freedom",
  "description": "matterbridge-ac-freedom v. 2.1.6 by https://github.com/azadaydinli",
  "type": "object",
  "properties": {
    "name": {
      "title": "Plugin Name",
      "type": "string",
      "readOnly": true,
      "ui:widget": "hidden"
    },
    "type": {
      "title": "Plugin Type",
      "type": "string",
      "readOnly": true,
      "ui:widget": "hidden"
    },
    "debug": {
      "title": "Enable Debug",
      "description": "Enable debug logging",
      "type": "boolean",
      "default": false
    },
    "unregisterOnShutdown": {
      "title": "Unregister On Shutdown",
      "type": "boolean",
      "default": false,
      "ui:widget": "hidden"
    },
    "cloudDevices": {
      "title": "Cloud Devices",
      "description": "AUX AC devices controlled via cloud (BroadLink SmartHomeCS)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "email", "password"],
        "properties": {
          "name": {
            "title": "Device Name",
            "type": "string"
          },
          "email": {
            "title": "Email",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string",
            "ui:widget": "password"
          },
          "region": {
            "title": "Region",
            "description": "Type: eu (Europe), usa (USA), cn (China), rus (Russia)",
            "type": "string",
            "default": "eu"
          },
          "deviceId": {
            "title": "Device ID",
            "description": "Leave empty to auto-detect",
            "type": "string"
          },
          "showExtras": {
            "title": "Extra Controls",
            "description": "Add fan speed control and sleep mode switch inside the climate card",
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "localDevices": {
      "title": "Local Devices",
      "description": "AUX AC devices controlled via local network (Broadlink UDP)",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "ip", "mac"],
        "properties": {
          "name": {
            "title": "Device Name",
            "type": "string"
          },
          "ip": {
            "title": "IP Address",
            "type": "string"
          },
          "mac": {
            "title": "MAC Address",
            "description": "Format: AA:BB:CC:DD:EE:FF",
            "type": "string"
          },
          "showExtras": {
            "title": "Extra Controls",
            "description": "Add fan speed control and sleep mode switch inside the climate card",
            "type": "boolean",
            "default": false
          }
        }
      }
    }
  }
}
